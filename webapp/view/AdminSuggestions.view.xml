<mvc:View
  controllerName="sap.favorites.controller.AdminSuggestions"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:mvc="sap.ui.core.mvc">

  <VBox class="favAdminPane">
    <Toolbar>
      <Title text="{i18n>tabSuggestions}" level="H2" />
      <ToolbarSpacer />
      <Button icon="sap-icon://refresh" text="Refresh" type="Transparent" press=".onRefresh" />
    </Toolbar>

    <List
      id="suggestionsList"
      items="{/suggestions}"
      growing="true"
      noDataText="No pending suggestions">
      <CustomListItem class="favSuggestion">
        <HBox justifyContent="SpaceBetween" alignItems="Center" width="100%" class="sapUiSmallMargin">
          <VBox class="favSuggestionBody">
            <HBox alignItems="Center" wrap="Wrap">
              <Title text="{title}" level="H4" wrapping="true" class="sapUiTinyMarginEnd" />
              <Label text="{ path: 'type', formatter: '.formatter.typeLabel' }" class="favBadge">
                <customData>
                  <core:CustomData key="badgeType" value="{type}" writeToDom="true" />
                </customData>
              </Label>
            </HBox>
            <Text text="{subtitle}" class="favMuted" />
            <Text text="{description}" maxLines="2" class="favSuggestionDesc" />
          </VBox>
          <HBox class="favSuggestionActions" alignItems="Center">
            <Button icon="sap-icon://action" tooltip="Open link" type="Transparent" press=".onOpen" />
            <Button text="{i18n>approve}" icon="sap-icon://accept" type="Accept" press=".onApprove" class="sapUiTinyMarginBegin" />
            <Button text="{i18n>reject}" icon="sap-icon://decline" type="Reject" press=".onReject" class="sapUiTinyMarginBegin" />
          </HBox>
        </HBox>
      </CustomListItem>
    </List>
  </VBox>
</mvc:View>
