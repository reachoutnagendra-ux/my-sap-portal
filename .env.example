# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://favorites:favorites@localhost:5432/favorites

# Auth
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_PIN=1234

# Preview fetching (optional, improves quality)
YOUTUBE_API_KEY=
GITHUB_TOKEN=

# AI (set adapter name; leave blank or 'noop' to use the safe stub)
AI_ADAPTER=noop            # options: noop | openai | anthropic | ollama
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
